        },
        {
            "before": [
                "<leader>",
                "g",
                "c"
            ],
            "commands": [
                "git.commit"
            ]
        },
        {
            "before": [
                "<leader>",
                "g",
                "p"
            ],
            "commands": [
                "git.push"
